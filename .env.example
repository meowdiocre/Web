# --- Neon Postgres ----------------------------------------------------------
# Pooled connection (HTTP, used at runtime in Vercel functions).
DATABASE_URL=postgres://USER:PASSWORD@ep-XXXX-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require
# Unpooled connection (TCP, used by drizzle-kit migrate + studio).
DATABASE_URL_UNPOOLED=postgres://USER:PASSWORD@ep-XXXX.eu-central-1.aws.neon.tech/neondb?sslmode=require

# --- GitHub OAuth -----------------------------------------------------------
# Create at https://github.com/settings/developers
# Authorization callback URL: https://your-site.example/admin/callback
GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# The single GitHub login allowed to access /admin/*.
ADMIN_GITHUB_LOGIN=devirtz

# --- Sessions + signed previews --------------------------------------------
# Generate with `openssl rand -base64 48` (or `node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"`).
SESSION_SECRET=replace-me-with-a-long-random-string-please

# --- Vercel revalidate + cron ----------------------------------------------
# Bypass token from Vercel project settings -> Deployment Protection.
VERCEL_REVALIDATE_URL=https://your-site.example
# Used by the cron handler to authenticate Vercel's request.
CRON_SECRET=replace-me-with-another-random-string

# --- Vercel Blob (set automatically when you enable the integration) -------
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxx

# --- Site --------------------------------------------------------------------
PUBLIC_SITE_URL=http://localhost:5173
