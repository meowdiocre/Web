# Dependencies
node_modules/

# Build output
build/
.svelte-kit/
.vercel/
.vite/

# Vite leaves a timestamped pre-bundle when a dev start fails halfway.
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Local tools
.codex/

# Environment and secrets
.env
.env.*
!.env.example

# Test artifacts
coverage/
test-results/
playwright-report/
playwright/.cache/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor and OS files
.DS_Store
Thumbs.db
.idea/
*.swp
*.swo
*.tsbuildinfo

# Keep shared VS Code config; ignore everything else under .vscode/.
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
