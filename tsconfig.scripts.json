{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "lib": ["es2023", "dom"],
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "$lib/*": ["src/lib/*"],
      "$db/*":  ["src/lib/server/db/*"]
    }
  },
  "include": ["src/**/*", "drizzle/**/*", "scripts/**/*"]
}
